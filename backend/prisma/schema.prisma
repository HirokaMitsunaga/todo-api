generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        String     @id
  title     String
  status    TodoStatus
  priority  Int
  user      User       @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model User {
  id        String   @id
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  todos     Todo[]
}

enum TodoStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}
